<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.Endereco"
             Title="Endereco"  
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#d3cdef">

    <VerticalStackLayout VerticalOptions="CenterAndExpand" Padding="12" Spacing="20">
        <Image Source="logohotel.png" HeightRequest="250"/>
        <Border Padding="10" Stroke="#0F5257" StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="7"/>
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="10">
                <Label Text="Rua Estrela d'Ouro, 554" HorizontalTextAlignment="Center" TextColor ="#0F5257" FontSize="25" FontFamily="VarelaRound"/>
                <Label Text="São Paulo - SP - Brasil" HorizontalTextAlignment="Center" TextColor ="#0F5257" FontSize="25" FontFamily="VarelaRound"/>
                <Label Text="Cep: 1215478-336" HorizontalTextAlignment="Center" TextColor ="#0F5257" FontSize="25" FontFamily="VarelaRound"/>
                <Label Text="Hotel Estrelar" HorizontalTextAlignment="Center" TextColor ="#0F5257" FontSize="25" FontFamily="VarelaRound"/>
            </VerticalStackLayout>
        </Border>
        <Button Text="Voltar" BackgroundColor="#0F5257" HorizontalOptions="Start" Clicked="Button_Clicked"/>
    </VerticalStackLayout>
</ContentPage>